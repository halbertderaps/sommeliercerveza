  { id:'citrus', number:'Pregunta 2 · Aromas cítricos', text:'¿Te gustan los sabores cítricos o tropicales?', hint:'Como pomelo, mango, maracuyá… los lúpulos modernos pueden dar esas notas',
    options:[{value:'yes',emoji:'🍋',label:'Sí, me encantan',sub:'Frescos y aromáticos'},{value:'neutral',emoji:'😐',label:'Me da igual',sub:'No es algo que busque'},{value:'no',emoji:'🙅',label:'No me van',sub:'Prefiero algo más clásico y neutro'}]},
  { id:'sweetness', number:'Pregunta 3 · Malta y dulzor', text:'¿Prefieres sabores dulces y tostados, o secos y limpios?', hint:'La malta es el "pan" de la cerveza. Puede aportar caramelo, chocolate o ser muy neutra',
    options:[{value:'sweet',emoji:'🍯',label:'Dulces y tostados',sub:'Caramelo, pan, chocolate'},{value:'balanced',emoji:'⚖️',label:'Un equilibrio',sub:'Ni muy dulce ni muy seca'},{value:'dry',emoji:'🏜️',label:'Seca y limpia',sub:'Sin dulzor, muy refrescante'}]},
  { id:'body', number:'Pregunta 4 · Cuerpo', text:'¿La quieres ligera o con cuerpo?', hint:'El cuerpo es la sensación en boca: puede ser fina como agua o densa como un zumo',
    options:[{value:'light',emoji:'🪶',label:'Ligera',sub:'Que baje sola, sin esfuerzo'},{value:'medium',emoji:'🌊',label:'Intermedia',sub:'Algo de textura pero no pesada'},{value:'full',emoji:'🏋️',label:'Con mucho cuerpo',sub:'Densa, que se note en boca'}]},
