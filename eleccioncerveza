<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>El Sommelier de Cervezas</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C8973A;
    --amber: #8B4513;
    --dark: #0D0A07;
    --dark2: #1A1208;
    --dark3: #241A0E;
    --cream: #F5EDD8;
    --text: #D4C4A0;
    --text-dim: #8A7A5A;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--dark); color:var(--text); font-family:'Crimson Pro',Georgia,serif; min-height:100vh; overflow-x:hidden; }
  body::before {
    content:''; position:fixed; inset:0;
    background: radial-gradient(ellipse at 20% 20%,rgba(200,151,58,.07) 0%,transparent 50%),
                radial-gradient(ellipse at 80% 80%,rgba(139,69,19,.1) 0%,transparent 50%);
    pointer-events:none; z-index:0;
  }
  .container { position:relative; z-index:1; max-width:680px; margin:0 auto; padding:0 20px 60px; }

  /* Header */
  .header { text-align:center; padding:50px 0 40px; border-bottom:1px solid rgba(200,151,58,.2); margin-bottom:40px; }
  .header-icon { font-size:2.8rem; margin-bottom:12px; display:block; filter:drop-shadow(0 0 12px rgba(200,151,58,.4)); }
  .header h1 { font-family:'Playfair Display',serif; font-size:clamp(2rem,6vw,3rem); font-weight:900; color:var(--gold); letter-spacing:.02em; line-height:1.1; text-shadow:0 2px 20px rgba(200,151,58,.3); }
  .header p { margin-top:10px; font-size:1.05rem; color:var(--text-dim); font-style:italic; letter-spacing:.05em; }

  /* Progress */
  .progress-container { margin-bottom:32px; }
  .progress-info { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:8px; }
  .progress-label { font-size:.8rem; color:var(--text-dim); letter-spacing:.1em; text-transform:uppercase; }
  .progress-count { font-family:'Playfair Display',serif; font-size:1.1rem; color:var(--gold); }
  .progress-bar { height:3px; background:rgba(200,151,58,.15); border-radius:2px; overflow:hidden; }
  .progress-fill { height:100%; background:linear-gradient(90deg,var(--amber),var(--gold)); border-radius:2px; transition:width .5s cubic-bezier(.4,0,.2,1); box-shadow:0 0 8px rgba(200,151,58,.5); }

  /* Question card */
  .question-card { background:var(--dark2); border:1px solid rgba(200,151,58,.15); border-radius:2px; padding:36px 32px; position:relative; overflow:hidden; animation:slideIn .4s cubic-bezier(.4,0,.2,1); }
  .question-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg,transparent,var(--gold),transparent); }
  @keyframes slideIn { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
  .question-number { font-size:.72rem; color:var(--gold); letter-spacing:.18em; text-transform:uppercase; margin-bottom:14px; }
  .question-text { font-family:'Playfair Display',serif; font-size:clamp(1.3rem,3.5vw,1.7rem); font-weight:700; color:var(--cream); line-height:1.3; margin-bottom:8px; }
  .question-hint { font-size:.92rem; color:var(--text-dim); font-style:italic; margin-bottom:28px; line-height:1.5; }

  /* Options */
  .options { display:flex; flex-direction:column; gap:10px; }
  .option-btn { background:var(--dark3); border:1px solid rgba(200,151,58,.12); border-radius:2px; padding:14px 20px; color:var(--text); font-family:'Crimson Pro',serif; font-size:1.05rem; cursor:pointer; text-align:left; transition:all .25s ease; display:flex; align-items:center; gap:14px; position:relative; overflow:hidden; }
  .option-btn::before { content:''; position:absolute; left:0; top:0; bottom:0; width:0; background:linear-gradient(90deg,rgba(200,151,58,.12),transparent); transition:width .3s ease; }
  .option-btn:hover::before { width:100%; }
  .option-btn:hover { border-color:rgba(200,151,58,.4); color:var(--cream); transform:translateX(4px); }
  .option-btn.selected { border-color:var(--gold); background:rgba(200,151,58,.08); color:var(--cream); }
  .option-btn.selected::before { width:100%; }
  .option-emoji { font-size:1.3rem; width:28px; text-align:center; flex-shrink:0; position:relative; z-index:1; }
  .option-text { position:relative; z-index:1; }
  .option-label { display:block; font-weight:600; margin-bottom:1px; }
  .option-sub { font-size:.82rem; color:var(--text-dim); font-style:italic; }

  /* Text input */
  .text-input { width:100%; background:var(--dark3); border:1px solid rgba(200,151,58,.2); border-radius:2px; padding:14px 18px; color:var(--cream); font-family:'Crimson Pro',serif; font-size:1.05rem; outline:none; transition:border-color .25s; }
  .text-input:focus { border-color:var(--gold); }
  .text-input::placeholder { color:var(--text-dim); font-style:italic; }

  /* Nav */
  .nav { display:flex; justify-content:space-between; align-items:center; margin-top:28px; gap:12px; }
  .btn-back { background:transparent; border:1px solid rgba(200,151,58,.2); border-radius:2px; padding:12px 20px; color:var(--text-dim); font-family:'Crimson Pro',serif; font-size:1rem; cursor:pointer; transition:all .2s; }
  .btn-back:hover { border-color:rgba(200,151,58,.4); color:var(--text); }
  .btn-next { background:linear-gradient(135deg,var(--amber),var(--gold)); border:none; border-radius:2px; padding:14px 32px; color:var(--dark); font-family:'Playfair Display',serif; font-size:1rem; font-weight:700; cursor:pointer; letter-spacing:.05em; transition:all .25s ease; flex:1; max-width:260px; box-shadow:0 4px 20px rgba(200,151,58,.25); }
  .btn-next:hover:not(:disabled) { box-shadow:0 6px 28px rgba(200,151,58,.45); transform:translateY(-1px); }
  .btn-next:disabled { opacity:.35; cursor:not-allowed; transform:none; }

  /* Results */
  .results { animation:fadeIn .5s ease; }
  @keyframes fadeIn { from{opacity:0} to{opacity:1} }
  .results-header { text-align:center; margin-bottom:36px; }
  .results-header h2 { font-family:'Playfair Display',serif; font-size:clamp(1.6rem,5vw,2.2rem); color:var(--gold); margin-bottom:8px; }
  .results-header p { color:var(--text-dim); font-style:italic; font-size:1rem; }

  /* Beer card */
  .beer-card { background:var(--dark2); border:1px solid rgba(200,151,58,.15); border-radius:2px; padding:0; margin-bottom:20px; position:relative; overflow:hidden; animation:slideIn .4s cubic-bezier(.4,0,.2,1) both; }
  .beer-card:nth-child(2){animation-delay:.1s} .beer-card:nth-child(3){animation-delay:.2s}
  .beer-card.gold-card   { border-color:rgba(200,151,58,.5); }
  .beer-card.silver-card { border-color:rgba(192,192,192,.4); }
  .beer-card.bronze-card { border-color:rgba(180,120,60,.4); }
  .beer-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; z-index:2; }
  .beer-card.gold-card::before   { background:linear-gradient(90deg,transparent,#C8973A,transparent); }
  .beer-card.silver-card::before { background:linear-gradient(90deg,transparent,#C0C0C0,transparent); }
  .beer-card.bronze-card::before { background:linear-gradient(90deg,transparent,#B4783C,transparent); }

  .beer-card-top { display:flex; align-items:stretch; }
  .beer-img-wrap { flex-shrink:0; width:110px; min-height:160px; background:rgba(0,0,0,.25); display:flex; align-items:center; justify-content:center; padding:16px 10px; border-right:1px solid rgba(200,151,58,.1); position:relative; overflow:hidden; }
  .beer-img-wrap::after { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at center,rgba(200,151,58,.04) 0%,transparent 70%); }
  .beer-img { width:72px; height:130px; object-fit:contain; display:block; filter:drop-shadow(0 4px 14px rgba(0,0,0,.6)); position:relative; z-index:1; transition:transform .3s ease; }
  .beer-card:hover .beer-img { transform:scale(1.05) translateY(-2px); }
  .beer-img-fallback { font-size:3.5rem; filter:drop-shadow(0 2px 8px rgba(0,0,0,.5)); position:relative; z-index:1; }
  .beer-card-header { flex:1; padding:22px 22px 18px; display:flex; flex-direction:column; justify-content:center; }
  .medal-row { display:flex; align-items:center; gap:10px; margin-bottom:10px; }
  .medal { font-size:1.6rem; filter:drop-shadow(0 2px 6px rgba(0,0,0,.4)); }
  .medal-label { font-size:.68rem; letter-spacing:.18em; text-transform:uppercase; opacity:.65; }
  .beer-name { font-family:'Playfair Display',serif; font-size:clamp(1.05rem,3vw,1.35rem); font-weight:700; color:var(--cream); margin-bottom:8px; line-height:1.25; }
  .beer-meta { display:flex; gap:12px; flex-wrap:wrap; }
  .beer-tag { font-size:.78rem; color:var(--gold); letter-spacing:.05em; opacity:.85; }

  /* Afinidad bar */
  .affinity-wrap { padding:0 22px 14px; display:flex; align-items:center; gap:10px; }
  .affinity-track { flex:1; height:3px; background:rgba(200,151,58,.15); border-radius:2px; }
  .affinity-fill { height:100%; border-radius:2px; background:linear-gradient(90deg,var(--amber),var(--gold)); transition:width 1s ease; }
  .affinity-label { font-size:.72rem; color:var(--text-dim); letter-spacing:.08em; white-space:nowrap; }

  .beer-why { font-size:1rem; color:var(--text); line-height:1.75; border-top:1px solid rgba(200,151,58,.1); padding:18px 22px 22px; }

  /* Divider & closing */
  .divider { text-align:center; margin:32px 0; color:var(--text-dim); font-size:.75rem; letter-spacing:.2em; text-transform:uppercase; }
  .divider::before,.divider::after { content:'— '; }
  .closing-note { text-align:center; padding:10px 20px 0; font-style:italic; color:var(--text-dim); font-size:1.05rem; line-height:1.7; }

  /* Restart */
  .restart-wrap { text-align:center; margin-top:36px; }
  .btn-restart { background:transparent; border:1px solid rgba(200,151,58,.35); border-radius:2px; padding:14px 36px; color:var(--gold); font-family:'Playfair Display',serif; font-size:1rem; font-weight:700; cursor:pointer; letter-spacing:.08em; transition:all .25s; }
  .btn-restart:hover { background:rgba(200,151,58,.08); border-color:var(--gold); transform:translateY(-1px); }

  @media(max-width:480px){
    .question-card{padding:24px 20px} .beer-img-wrap{width:84px;min-height:130px}
    .beer-img{width:58px;height:108px} .beer-card-header{padding:16px 14px 14px}
    .beer-why{padding:14px 14px 16px} .affinity-wrap{padding:0 14px 14px}
    .nav{flex-wrap:wrap} .btn-next{max-width:none}
  }
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <span class="header-icon">🍺</span>
    <h1>El Sommelier<br>de Cervezas</h1>
    <p>Encuentra tu cerveza perfecta en 8 preguntas</p>
  </div>
  <div id="app"></div>
</div>
<script>
// ─────────────────────────────────────────
// CATÁLOGO
// ─────────────────────────────────────────
const BEERS = [
  {
    name:"Estrella Galicia 1906 Reserva Especial", style:"Lager Premium", abv:"6.5%", emoji:"🍺",
    img:"https://www.estrellagalicia.es/sites/default/files/styles/product_detail/public/product-images/1906_reserva_especial_33cl.png",
    scores:{ bitterness:{none:1,little:3,much:1}, citrus:{yes:1,neutral:3,no:2}, sweetness:{sweet:1,balanced:3,dry:2}, body:{light:1,medium:3,full:2}, color:{pale:3,amber:1,dark:0}, alcohol:{low:1,any:3,high:2}, context:{refresh:2,savor:3,food:2} },
    why:"La 1906 Reserva Especial es la joya de la corona de Estrella Galicia. Se elabora con una fermentación lenta a baja temperatura que le da una textura sedosa y un sabor profundo y limpio. Con 6.5% de alcohol, tiene más cuerpo que una lager convencional pero sin resultar pesada. En boca aparecen notas de malta ligeramente tostada, un amargor suave y equilibrado, y un final largo y refrescante. Una cerveza pensada para quienes valoran la calidad por encima de la cantidad.",
  },
  {
    name:"Ámbar Export", style:"Lager Ámbar", abv:"5.2%", emoji:"🍺",
    img:"https://www.cervezasambar.com/wp-content/uploads/2020/10/ambar-export-botella-33cl.png",
    scores:{ bitterness:{none:2,little:3,much:1}, citrus:{yes:0,neutral:3,no:3}, sweetness:{sweet:3,balanced:2,dry:0}, body:{light:1,medium:3,full:2}, color:{pale:1,amber:3,dark:1}, alcohol:{low:2,any:3,high:1}, context:{refresh:2,savor:2,food:3} },
    why:"La Ámbar Export es un orgullo aragonés con décadas de historia. Su color ámbar dorado ya avanza lo que el paladar va a encontrar: notas de caramelo y malta tostada, con un dulzor cálido que recuerda al pan recién horneado. El amargor es casi inexistente, lo que la convierte en una cerveza muy accesible. Su cuerpo redondo y su suavidad la hacen especialmente buena para acompañar comidas de cuchara, asados o tapas contundentes. Una cerveza honesta y sin pretensiones.",
  },
  {
    name:"Alhambra Reserva 1925", style:"Lager Premium", abv:"6.4%", emoji:"🍺",
    img:"https://www.cervezasalhambra.es/sites/default/files/2022-03/alhambra-reserva-1925-33cl.png",
    scores:{ bitterness:{none:1,little:3,much:1}, citrus:{yes:1,neutral:3,no:2}, sweetness:{sweet:2,balanced:3,dry:1}, body:{light:1,medium:2,full:3}, color:{pale:2,amber:2,dark:1}, alcohol:{low:1,any:3,high:2}, context:{refresh:1,savor:3,food:2} },
    why:"La Reserva 1925 es la cerveza más icónica de Granada. Se fermenta con lúpulo en flor —una técnica casi olvidada— lo que le aporta aromas florales y herbales únicos que no encontrarás en ninguna otra lager española. Con 6.4% y un cuerpo generoso, es una cerveza que pide atención: sirviéndola en copa ancha se liberan mejor sus aromas. En boca es redonda, con malta equilibrada y un final persistente. Ideal para beberla despacio, acompañada de buena conversación.",
  },
  {
    name:"Mahou 5 Estrellas", style:"Lager", abv:"5.5%", emoji:"🍺",
    img:"https://www.mahou.es/sites/default/files/styles/product_image/public/2021-04/mahou-5-estrellas-botella-33cl.png",
    scores:{ bitterness:{none:2,little:3,much:0}, citrus:{yes:0,neutral:3,no:3}, sweetness:{sweet:2,balanced:3,dry:1}, body:{light:2,medium:3,full:1}, color:{pale:3,amber:1,dark:0}, alcohol:{low:2,any:3,high:1}, context:{refresh:3,savor:1,food:2} },
    why:"La Mahou 5 Estrellas es la cerveza de Madrid por excelencia, y hay una razón por la que lleva décadas siendo la más vendida en la capital. Su fórmula es perfecta en su sencillez: color dorado brillante, espuma cremosa y persistente, amargor muy suave y un sabor limpio y refrescante que no cansa nunca. Con 5.5% tiene algo más de cuerpo que otras lagers sin llegar a ser pesada. Perfecta para tomar en terraza, con unas bravas o simplemente para aplacar el calor. La cerveza del pueblo.",
  },
  {
    name:"Damm Inedit", style:"Witbier / Lager híbrida", abv:"4.8%", emoji:"🍺",
    img:"https://www.damm.com/sites/default/files/styles/product_detail/public/2021-09/inedit-33cl-botella.png",
    scores:{ bitterness:{none:3,little:2,much:0}, citrus:{yes:3,neutral:2,no:0}, sweetness:{sweet:3,balanced:2,dry:0}, body:{light:3,medium:2,full:0}, color:{pale:3,amber:1,dark:0}, alcohol:{low:3,any:2,high:0}, context:{refresh:3,savor:2,food:3} },
    why:"La Inedit nació de la colaboración entre la cervecería Damm y el chef Ferran Adrià con un objetivo muy concreto: crear la cerveza perfecta para maridar con comida. El resultado es una mezcla única de cebada y trigo con especias como el cilantro y la piel de naranja, inspirada en las witbier belgas. Es la cerveza más gastronómica de todas las disponibles: ligera, suave, sin rastro de amargor, con aromas cítricos y un punto especiado que complementa desde mariscos hasta postres. Perfecta también para quienes se acercan por primera vez a la cerveza de autor.",
  },
  {
    name:"Águila Sin Filtrar", style:"Lager sin filtrar", abv:"5.0%", emoji:"🍺",
    img:"https://www.cervezaaguila.com/sites/default/files/product-images/aguila-sin-filtrar-33cl.png",
    scores:{ bitterness:{none:2,little:3,much:1}, citrus:{yes:2,neutral:3,no:2}, sweetness:{sweet:1,balanced:3,dry:2}, body:{light:3,medium:2,full:0}, color:{pale:3,amber:1,dark:0}, alcohol:{low:3,any:2,high:0}, context:{refresh:3,savor:1,food:2} },
    why:"A diferencia de la mayoría de cervezas industriales, el Águila Sin Filtrar no pasa por el proceso de filtrado, lo que significa que conserva las levaduras y proteínas naturales del proceso de fermentación. El resultado es una cerveza con un aspecto ligeramente turbio y dorado, y un sabor notablemente más rico y complejo que una lager convencional. En boca es ligera pero con textura, con notas de cereal fresco, levadura y un ligero toque frutal. Muy refrescante y más interesante de lo que aparenta ser.",
  },
  {
    name:"Moritz 7", style:"Lager Fuerte", abv:"7.2%", emoji:"🍺",
    img:"https://www.moritz.com/wp-content/uploads/2021/05/moritz-7-botella-33cl.png",
    scores:{ bitterness:{none:1,little:2,much:3}, citrus:{yes:1,neutral:2,no:3}, sweetness:{sweet:2,balanced:2,dry:2}, body:{light:0,medium:2,full:3}, color:{pale:2,amber:3,dark:1}, alcohol:{low:0,any:2,high:3}, context:{refresh:1,savor:3,food:2} },
    why:"La Moritz 7 es la versión sin límites de una cervecería barcelonesa que siempre ha apostado por hacer las cosas bien. Con un 7.2% de alcohol que se integra de forma elegante, esta lager fuerte tiene un cuerpo denso y envolvente con notas pronunciadas de malta caramelizada, un amargor más marcado que sus hermanas menores y un largo postgusto que no desaparece deprisa. No es una cerveza para apagar la sed: es para quienes quieren algo con carácter, sentarse y disfrutarla de verdad.",
  },
  {
    name:"La Sagra IPA", style:"IPA", abv:"6.5%", emoji:"🌿",
    img:"https://images.openfoodfacts.org/images/products/841/700/000/0033/front_es.3.400.jpg",
    scores:{ bitterness:{none:0,little:1,much:3}, citrus:{yes:3,neutral:1,no:0}, sweetness:{sweet:0,balanced:1,dry:3}, body:{light:1,medium:3,full:1}, color:{pale:1,amber:3,dark:0}, alcohol:{low:0,any:2,high:3}, context:{refresh:1,savor:3,food:2} },
    why:"La Sagra IPA es una de las IPAs artesanales españolas más reconocidas, elaborada en Toledo con una selección de lúpulos americanos que aportan una explosión aromática de pomelo, fruta tropical y resina de pino. En boca es seca y con un amargor pronunciado y limpio —el sello de identidad de las buenas IPAs— con apenas dulzor residual. Con un 6.5% bien camuflado por los aromas, es la cerveza ideal para quienes quieren dar el salto del mundo lager al mundo craft sin mirar atrás.",
  },
  {
    name:"Chimay Azul", style:"Belgian Dark Strong Ale", abv:"9.0%", emoji:"🏔️",
    img:"https://www.chimay.com/sites/default/files/styles/product_detail/public/2020-11/chimay-bleue-33cl.png",
    scores:{ bitterness:{none:0,little:2,much:2}, citrus:{yes:0,neutral:2,no:3}, sweetness:{sweet:3,balanced:2,dry:0}, body:{light:0,medium:1,full:3}, color:{pale:0,amber:1,dark:3}, alcohol:{low:0,any:2,high:3}, context:{refresh:0,savor:3,food:2} },
    why:"La Chimay Azul es elaborada por los monjes trapenses de la Abadía de Scourmont (Bélgica) desde 1948, y es una de las cervezas más complejas y respetadas del mundo. Con un 9% de alcohol y un color oscuro y profundo, ofrece una experiencia sensorial única: aromas de frutos secos, ciruela, especias y cuero, seguidos de una boca densa con notas de caramelo oscuro, chocolate y un toque ligeramente alcohólico que se integra perfectamente. Cada sorbo es diferente. No es una cerveza, es una meditación.",
  },
  {
    name:"Westmalle Tripel", style:"Belgian Tripel", abv:"9.5%", emoji:"⛪",
    img:"https://www.westmalle.be/sites/default/files/styles/product/public/products/westmalle-tripel-33cl.png",
    scores:{ bitterness:{none:0,little:1,much:3}, citrus:{yes:3,neutral:2,no:0}, sweetness:{sweet:1,balanced:2,dry:3}, body:{light:0,medium:2,full:3}, color:{pale:3,amber:1,dark:0}, alcohol:{low:0,any:1,high:3}, context:{refresh:0,savor:3,food:1} },
    why:"La Westmalle Tripel es considerada por muchos expertos la madre de todas las tripeles belgas: fue esta abadía quien definió el estilo en los años 30. Con un 9.5% que se esconde detrás de su color dorado brillante, es una trampa deliciosa para el paladar. La nariz ofrece aromas de pera, manzana, flores y especias de levadura; en boca es seca, efervescente y con un largo final amargo. Cada botella fermenta dos veces —una en la cuba y otra en la propia botella— lo que la hace viva y única. Para beberla en copa de tulipa, nunca de botella.",
  },
  {
    name:"Duvel", style:"Belgian Strong Golden Ale", abv:"8.5%", emoji:"👿",
    img:"https://www.duvel.com/sites/default/files/styles/product_detail/public/products/duvel-33cl-bottle.png",
    scores:{ bitterness:{none:0,little:2,much:3}, citrus:{yes:2,neutral:2,no:1}, sweetness:{sweet:0,balanced:2,dry:3}, body:{light:0,medium:2,full:3}, color:{pale:3,amber:1,dark:0}, alcohol:{low:0,any:2,high:3}, context:{refresh:0,savor:3,food:1} },
    why:"Duvel significa \"diablo\" en flamenco, y el nombre no es casual: esta cerveza belga dorada y aparentemente ligera esconde un 8.5% de alcohol con una elegancia que desconcierta. Fermentada a baja temperatura durante semanas y refermentada en botella, desarrolla una espuma densa y persistente y una carbonatación fina que la hace bailar en copa. Su sabor es seco, ligeramente amargo y con notas de pera y azúcar candi. Una de las cervezas más técnicas y sofisticadas del mundo, y sin embargo sorprendentemente fácil de beber. Con cuidado.",
  },
