// ─────────────────────────────────────────
// PREGUNTAS
// ─────────────────────────────────────────
const QUESTIONS = [
  { id:'bitterness', number:'Pregunta 1 · Amargor', text:'¿Cómo llevas el amargor?', hint:'El amargor viene del lúpulo y es uno de los grandes rasgos de una cerveza',
