];

// ─────────────────────────────────────────
// MOTOR DE PUNTUACIÓN
// ─────────────────────────────────────────
function scoreBeers(answers) {
  const keys = ['bitterness','citrus','sweetness','body','color','alcohol','context'];
  return BEERS.map(beer => {
    let score = 0, max = keys.length * 3;
    keys.forEach(k => { if (answers[k]) score += (beer.scores[k][answers[k]] || 0); });
    if (answers.experience && answers.experience.trim()) {
      const ref = answers.experience.toLowerCase();
      Object.entries(REF_KEYWORDS).forEach(([kw, names]) => {
        if (ref.includes(kw) && names.includes(beer.name)) score += 4;
      });
      max += 4;
    }
    return { beer, score, pct: Math.round(score / max * 100) };
  }).sort((a,b) => b.score - a.score);
}

// ─────────────────────────────────────────
// ESTADO & RENDER
// ─────────────────────────────────────────
let currentQ = 0, answers = {};

function render() {
  const app = document.getElementById('app');
  currentQ < QUESTIONS.length ? renderQuestion(app) : renderResults(app);
}

function renderQuestion(app) {
  const q = QUESTIONS[currentQ];
  const isText = q.type === 'text';
  const pct = (currentQ / QUESTIONS.length) * 100;
  app.innerHTML = `
    <div class="progress-container">
      <div class="progress-info">
        <span class="progress-label">Tu perfil cervecero</span>
        <span class="progress-count">${currentQ+1} / ${QUESTIONS.length}</span>
      </div>
      <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
    </div>
    <div class="question-card">
      <div class="question-number">${q.number}</div>
      <div class="question-text">${q.text}</div>
      <div class="question-hint">${q.hint}</div>
      ${isText
        ? `<input type="text" class="text-input" id="textAnswer" placeholder="${q.placeholder}" value="${answers[q.id]||''}" oninput="answers['${q.id}']=this.value" onkeydown="if(event.key==='Enter')advanceText()">`
        : `<div class="options">${q.options.map(o=>`
            <button class="option-btn ${answers[q.id]===o.value?'selected':''}" onclick="selectAndAdvance('${q.id}','${o.value}',this)">
              <span class="option-emoji">${o.emoji}</span>
              <span class="option-text"><span class="option-label">${o.label}</span><span class="option-sub">${o.sub}</span></span>
            </button>`).join('')}</div>`
      }
    </div>
    <div class="nav">
      ${currentQ>0 ? `<button class="btn-back" onclick="prevQ()">← Anterior</button>` : `<span></span>`}
      ${isText ? `<button class="btn-next" onclick="advanceText()">Ver mi recomendación 🍺</button>` : ''}
    </div>`;
  if (isText) setTimeout(()=>document.getElementById('textAnswer')?.focus(),80);
}

function selectAndAdvance(qId, val, btn) {
  answers[qId] = val;
  document.querySelectorAll('.option-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
  // Small delay so the user sees the selection before moving on
  setTimeout(() => {
    currentQ++;
    window.scrollTo({top:0,behavior:'smooth'});
    render();
  }, 300);
}

function advanceText(){
  if(answers.experience && !answers.experience.trim()) delete answers.experience;
  currentQ++;
  window.scrollTo({top:0,behavior:'smooth'});
  render();
}

function prevQ(){ if(currentQ>0){currentQ--;window.scrollTo({top:0,behavior:'smooth'});render();} }

function renderResults(app){
  const ranked = scoreBeers(answers);
  const top3   = ranked.slice(0,3);
  const medals = [
    {medal:'🥇',label:'Oro · Tu mejor opción',      cls:'gold-card'},
    {medal:'🥈',label:'Plata · Excelente alternativa',cls:'silver-card'},
    {medal:'🥉',label:'Bronce · Para explorar',      cls:'bronze-card'},
  ];
  app.innerHTML = `
    <div class="results">
      <div class="results-header">
        <h2>Tu selección personal</h2>
        <p>Basado en tu perfil, el sommelier recomienda…</p>
      </div>
      ${top3.map((item,i)=>`
        <div class="beer-card ${medals[i].cls}">
          <div class="beer-card-top">
            <div class="beer-img-wrap">
              ${item.beer.img
                ? `<img class="beer-img" src="${item.beer.img}" alt="${item.beer.name}" onerror="this.style.display='none';this.nextElementSibling.style.display='block'"><span class="beer-img-fallback" style="display:none">${item.beer.emoji}</span>`
                : `<span class="beer-img-fallback">${item.beer.emoji}</span>`}
            </div>
            <div class="beer-card-header">
              <div class="medal-row">
                <span class="medal">${medals[i].medal}</span>
                <span class="medal-label">${medals[i].label}</span>
              </div>
              <div class="beer-name">${item.beer.name}</div>
              <div class="beer-meta">
                <span class="beer-tag">🍺 ${item.beer.style}</span>
                <span class="beer-tag">🔢 ${item.beer.abv} vol.</span>
              </div>
            </div>
          </div>
          <div class="affinity-wrap">
            <div class="affinity-track"><div class="affinity-fill" style="width:${item.pct}%"></div></div>
            <span class="affinity-label">Afinidad ${item.pct}%</span>
          </div>
          <div class="beer-why">${item.beer.why}</div>
        </div>
      `).join('')}
      <div class="divider">el sommelier dice</div>
      <div class="closing-note">"${closingNote(answers,top3[0].beer)}"</div>
      <div class="restart-wrap">
        <button class="btn-restart" onclick="restart()">🔄 Empezar de nuevo</button>
      </div>
    </div>`;
  window.scrollTo({top:0,behavior:'smooth'});
}

function closingNote(a, topBeer){
  if(a.context==='refresh') return "Nada mejor que una buena cerveza fría para refrescarse. ¡Que la disfrutes!";
  if(a.context==='food')    return "Una buena cerveza eleva cualquier comida. ¡Buen provecho!";
  if(a.bitterness==='much') return "Los que aprecian el amargor son los verdaderos entendidos. ¡Salud!";
  if(a.alcohol==='high')    return "Las mejores cervezas del mundo son fuertes y complejas. Tómatela con calma. ¡Salud!";
  if(a.color==='dark')      return "Las cervezas oscuras son las más incomprendidas. Hoy vas a descubrir por qué merecen la pena.";
  return "La cerveza perfecta es la que disfrutas con quien quieres. ¡Salud!";
}

function restart(){ currentQ=0; answers={}; window.scrollTo({top:0,behavior:'smooth'}); render(); }

render();
</script>
